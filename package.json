{
  "builds": [
    {
      "src": "public/**/*",
      "use": "@vercel/static-build"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
   
        "includeFiles": ["lib/DATAV2.csv"] 
      }
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}