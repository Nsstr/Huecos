{
  "version": 2,
  "builds": [
    {
      "src": "api/cargar-datos.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["lib/datav2.csv", "lib/utils.js"]
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/cargar-datos",
      "dest": "api/cargar-datos.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}